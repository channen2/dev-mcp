# GitHub — Settings -> Developer settings -> Fine-grained personal access tokens
# Scope to the specific repo(s) this server will touch (not "all repositories").
# Permissions needed: Pull requests (Read and write), Checks (Read-only)
GITHUB_TOKEN=

# Jira Cloud — id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=

# Slack — api.slack.com/apps -> your app -> OAuth & Permissions -> Bot User OAuth Token
# Scopes needed: chat:write (plus chat:write.public if posting to public channels the bot hasn't joined)
SLACK_BOT_TOKEN=
